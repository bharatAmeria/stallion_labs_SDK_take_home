{
  "name": "react-native-bitnet",
  "version": "0.1.0",
  "description": "React Native SDK for BitNet.cpp — run 1-bit LLMs on-device via native bindings",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "react-native-bitnet.podspec",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest --testPathIgnorePatterns='integration'",
    "test:integration": "jest --testPathPattern='integration' --testEnvironment=node",
    "test:all": "jest",
    "build:run": "tsc --project tsconfig.run.json",
    "stage2": "node run-stage2.js",
    "stage2:list": "node run-stage2.js --list",
    "stage2:resolve": "node run-stage2.js --resolve",
    "stage2:delete": "node run-stage2.js --delete",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build lib",
    "prepare": "bob build",
    "example": "yarn --cwd example"
  },
  "keywords": [
    "react-native",
    "bitnet",
    "llm",
    "1-bit",
    "inference",
    "on-device",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/react-native-bitnet.git"
  },
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-org/react-native-bitnet/issues"
  },
  "homepage": "https://github.com/your-org/react-native-bitnet#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-blob-util": ">=0.19.0"
  },
  "peerDependenciesMeta": {
    "react-native-blob-util": {
      "optional": false
    }
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.74.0",
    "@react-native/eslint-config": "^0.74.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.0.0",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|@react-native/[^/]+)/)"
    ]
  },
  "codegenConfig": {
    "name": "RNBitNetSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
